# ==============================================================================
# .env.example — Template delle variabili d'ambiente (Social Privacy Detector)
# Copiare in .env (locale) o .env.production (EC2) e valorizzare i segreti.
# NON committare i file .env reali: contengono credenziali.
#
# REGOLA: mai commenti a FINE RIGA su una variabile — vanno sulla riga sopra.
# Docker Compose li include DENTRO il valore; python-dotenv (usato dai test da riga
# di comando) invece li rimuove. Il difetto si manifesta quindi SOLO nel container e
# non nei test, che è il modo peggiore di sbagliare. Vedi PII_LLM_BASE_URL sotto.
# ==============================================================================

# --- Modalità di esecuzione ---------------------------------------------------
# AWS_MOCK=true  → tutto in-process, nessuna chiamata AWS (sviluppo a costo zero)
# AWS_MOCK=false → usa i servizi AWS reali (produzione su EC2 con IAM role)
AWS_MOCK=true
ENV=development
AWS_DEFAULT_REGION=us-east-1

# --- Modalità worker (elaborazione distribuita) -------------------------------
# WORKER_MODE=inprocess → la pipeline gira in un thread nel backend (default)
# WORKER_MODE=sqs       → l'API invia i job a SQS e una Lambda li consuma
# SQS_QUEUE_URL: output "QueueUrl" dello stack CloudFormation (infra/cloud.yaml).
WORKER_MODE=inprocess
SQS_QUEUE_URL=

# --- Estrazione PII -----------------------------------------------------------
# presidio (default): NER italiano locale (spaCy) + recognizer custom — deterministico,
#          ispezionabile, funziona anche senza AWS. Richiede presidio-analyzer + spaCy +
#          modello it_core_news_lg (vedi requirements.txt).
# ensemble: Presidio + LLM esterno (solo nomi/luoghi/org, con grounding) usati insieme.
# comprehend: Amazon Comprehend + post-processing regex (solo con AWS_MOCK=false).
# regex: solo motore a regole (offline, base).
PII_PROVIDER=presidio

# --- LLM esterno per PII_PROVIDER=ensemble (OpenAI-compatible) -----------------
# Esempio Ollama Cloud:
#   PII_LLM_BASE_URL=https://ollama.com/v1
#   PII_LLM_MODEL=gpt-oss:20b
#   PII_LLM_API_KEY=<la tua key>
# Lasciare vuoto BASE_URL/MODEL disattiva l'LLM: ensemble degrada a Presidio-solo.
# NIENTE commenti a fine riga qui (vedi regola in testa al file): un URL con un
# commento attaccato fa fallire OGNI chiamata, in silenzio, e l'ensemble degrada a
# Presidio senza che si veda dal report — solo la confidenza lo tradisce (0.85
# invece di 0.95 sui nomi confermati da entrambi i motori).
PII_LLM_BASE_URL=
PII_LLM_MODEL=
# Modello di GENERAZIONE (report + esempio d'attacco). Vuoto = usa PII_LLM_MODEL.
# Tenerli separati NON e' pignoleria: estrarre entita' e scrivere prosa italiana sono
# compiti diversi e su Ollama vincono modelli diversi. Misurato sul set avversariale,
# 3 esecuzioni ciascuno: gpt-oss:20b R=0.83 stabile ma storpia l'italiano e ha
# allucinato un indirizzo; gpt-oss:120b scrive correttamente ma R=0.75-0.79.
GEN_LLM_MODEL=
PII_LLM_API_KEY=
# In alternativa alla key in chiaro: nome del parametro SSM SecureString (produzione).
PII_LLM_API_KEY_SSM=

# --- Modello di rischio -------------------------------------------------------
# empirical (default): Rischio = Σ Pₐ·Iₐ, con impatti/probabilità da studi (IC3 2025,
#            DBIR 2026, Proofpoint 2024) e framework NIST SP 800-30.
# heuristic: modello storico (pesi base + combo + compressione), disponibile come alternativa.
RISK_MODEL=empirical

# --- Scraping (Apify) ---------------------------------------------------------
# Token API Apify; con AWS_MOCK=true lo scraping usa dati simulati e va lasciato vuoto.
# Con AWS_MOCK=false il token e' OBBLIGATORIO: senza, lo scraping solleva un errore
# esplicito. NON ricade sui dati simulati, che in produzione sarebbero indistinguibili
# da un'analisi vera.
APIFY_API_TOKEN=
# In alternativa al token in chiaro: nome del parametro SSM SecureString (produzione).
APIFY_API_TOKEN_SSM=

# --- Persistenza AWS (usata solo con AWS_MOCK=false) --------------------------
DYNAMODB_TABLE=spd-analyses
S3_BUCKET=spd-uploads
# Ore di conservazione dei record (TTL DynamoDB + lifecycle S3) — GDPR storage limitation.
DATA_RETENTION_HOURS=24
# Tetto di immagini per post su cui eseguire l'OCR (contenimento costi Textract).
MAX_POST_IMAGES_OCR=6
# Analisi visiva delle immagini (Amazon Rekognition DetectLabels). "false" la disattiva.
ENABLE_REKOGNITION=true

# --- Generazione del report (LLM) ---------------------------------------------
# Provider intercambiabile: gemini (default) | mock
REPORT_PROVIDER=gemini
# Gemini via endpoint OpenAI-compatible (default nel codice se lasciate vuote).
# In LOCALE: metti la chiave qui in GEMINI_API_KEY.
# In PRODUZIONE: lascia GEMINI_API_KEY vuota e usa GEMINI_API_KEY_SSM = nome del
# parametro SSM SecureString (la chiave non sta in chiaro, si legge cifrata da SSM).
GEMINI_API_KEY=
GEMINI_API_KEY_SSM=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=

# --- Rete ---------------------------------------------------------------------
# Origini consentite per il CORS (in produzione dietro Nginx di solito non serve).
CORS_ALLOWED_ORIGINS=
