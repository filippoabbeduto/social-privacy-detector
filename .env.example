# ==============================================================================
# .env.example — Template delle variabili d'ambiente (Social Privacy Detector)
# Copiare in .env (locale) o .env.production (EC2) e valorizzare i segreti.
# NON committare i file .env reali: contengono credenziali.
# ==============================================================================

# --- Modalità di esecuzione ---------------------------------------------------
# AWS_MOCK=true  → tutto in-process, nessuna chiamata AWS (sviluppo a costo zero)
# AWS_MOCK=false → usa i servizi AWS reali (produzione su EC2 con IAM role)
AWS_MOCK=true
ENV=development
AWS_DEFAULT_REGION=us-east-1

# --- Modalità worker (elaborazione distribuita) -------------------------------
# WORKER_MODE=inprocess → la pipeline gira in un thread nel backend (default)
# WORKER_MODE=sqs       → l'API invia i job a SQS e una Lambda li consuma
# SQS_QUEUE_URL: output "QueueUrl" dello stack CloudFormation (infra/cloud.yaml).
WORKER_MODE=inprocess
SQS_QUEUE_URL=

# --- Scraping (Apify) ---------------------------------------------------------
# Token API Apify; con AWS_MOCK=true lo scraping usa dati simulati e va lasciato vuoto.
APIFY_API_TOKEN=

# --- Persistenza AWS (usata solo con AWS_MOCK=false) --------------------------
DYNAMODB_TABLE=spd-analyses
S3_BUCKET=spd-uploads
# Ore di conservazione dei record (TTL DynamoDB + lifecycle S3) — GDPR storage limitation.
DATA_RETENTION_HOURS=24
# Tetto di immagini per post su cui eseguire l'OCR (contenimento costi Textract).
MAX_POST_IMAGES_OCR=3
# Analisi visiva delle immagini (Amazon Rekognition DetectLabels). "false" la disattiva.
ENABLE_REKOGNITION=true

# --- Generazione del report (LLM) ---------------------------------------------
# Provider intercambiabile: gemini (default) | mock
REPORT_PROVIDER=gemini
# Gemini via endpoint OpenAI-compatible (default nel codice se lasciate vuote).
# In LOCALE: metti la chiave qui in GEMINI_API_KEY.
# In PRODUZIONE: lascia GEMINI_API_KEY vuota e usa GEMINI_API_KEY_SSM = nome del
# parametro SSM SecureString (la chiave non sta in chiaro, si legge cifrata da SSM).
GEMINI_API_KEY=
GEMINI_API_KEY_SSM=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=

# --- Rete ---------------------------------------------------------------------
# Origini consentite per il CORS (in produzione dietro Nginx di solito non serve).
CORS_ALLOWED_ORIGINS=
