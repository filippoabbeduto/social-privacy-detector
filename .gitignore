# ==============================================================================
# SOCIAL PRIVACY DETECTOR - .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/

# Node.js
node_modules/
build/
dist/
*.tsbuildinfo

# Environment & Secrets
.env
.env.local
.env.production
!.env.example
# Chiavi private (SSH/TLS): mai committare
*.pem
*.key
*.ppk
# Certificati self-signed generati localmente/sull'EC2 (contengono la chiave privata)
certs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
npm-debug.log*

# Coverage
coverage/
.nyc_output/

# AWS
.aws/

# Artefatti di build LaTeX (rigenerabili da relazione.tex)
relazione/*.aux
relazione/*.log
relazione/*.out
relazione/*.toc
